# ============================================================
# BraTS AI Backend — Environment Variables Reference
# Copy this to .env for local development.
# Set these in the Railway dashboard for production.
# ============================================================

# ── Django Core ──────────────────────────────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-strong-secret-key-here

DEBUG=False

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=your-app.up.railway.app,localhost,127.0.0.1

# ── CORS (Vercel frontend) ───────────────────────────────────
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173,http://localhost:3000

# ── Database ─────────────────────────────────────────────────
# Railway PostgreSQL plugin auto-injects DATABASE_URL
# For local dev: leave empty to use SQLite
DATABASE_URL=sqlite:///./db.sqlite3

# ── Redis Cache ──────────────────────────────────────────────
# Railway Redis plugin auto-injects REDIS_URL
# For local dev: install Redis locally or leave empty (cache disabled gracefully)
REDIS_URL=redis://localhost:6379/0

# ── Supabase File Storage (optional) ─────────────────────────
# Only needed if USE_SUPABASE_STORAGE=True (DEBUG=False + keys set)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_BUCKET=brats-files

# ── Model Path (optional override) ───────────────────────────
# Default: ./model/model.keras (local) or /app/model/model.keras (Docker)
# Override only if you store the model elsewhere
# MODEL_KERAS_PATH=/app/model/model.keras

# ── Media Files ──────────────────────────────────────────────
# On Railway, ephemeral disk is used if not overridden
# MEDIA_ROOT=/tmp/brats-media
